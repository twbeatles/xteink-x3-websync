# X3 WebSync Git Ignore

# Local Config / secrets / backups
config.json
config.json.bak
*.json.bak
.env
.env.*
*.local

# Epub Output & validation dumps
output/
*.epub

# Local DB & Logs
sync_history.db
*.db
*.db-journal
*.db-wal
*.db-shm
logs/
*.log

# Python Cache / tooling
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.pyright/
.ruff_cache/
.coverage
htmlcov/
.tox/
.hypothesis/
.cache/

# Virtual Environments
.venv/
venv/
ENV/
env/

# PyInstaller
build/
dist/
*.spec.bak
# keep x3_websync.spec tracked

# IDE / editor
.idea/
.vscode/
*.swp
*~
*.code-workspace

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Local agent / MCP / indexing (machine-local)
terminals/
mcps/
.codegraph/
.zcode/
.grok/
.cursor/

# Debug one-off scripts (local only; do not commit)
scripts/_debug_*.py
scripts/_tmp_*.py
